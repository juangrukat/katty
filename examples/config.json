{
  "model": {
    "provider": "deepseek",
    "model": "deepseek-v4-pro",
    "api_key_env": "DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com",
    "request_timeout_seconds": 120
  },
  "startup": {
    "max_file_chars": 60000,
    "files": [
      "~/.katty/soul.md",
      "~/.katty/preferences.md"
    ]
  },
  "environment": {
    "enabled": true,
    "include_path": true,
    "tool_checks": [
      "sh",
      "bash",
      "zsh",
      "git",
      "cc",
      "gcc",
      "clang",
      "make",
      "cmake",
      "ninja",
      "go",
      "python3",
      "perl",
      "awk",
      "sed",
      "grep",
      "find",
      "xargs",
      "tar",
      "gzip",
      "curl",
      "wget",
      "ssh",
      "scp",
      "rsync",
      "nc",
      "ping",
      "man",
      "gdb",
      "lldb",
      "strace",
      "truss",
      "ktrace",
      "dtrace",
      "perf",
      "bpftrace",
      "readelf",
      "objdump",
      "nm",
      "addr2line",
      "hexdump",
      "xxd"
    ]
  },
  "capabilities": {
    "scan_on_startup": true,
    "families": {
      "archive": [
        "tar",
        "gzip",
        "xz",
        "zip",
        "unzip"
      ],
      "build": [
        "make",
        "cmake",
        "ninja",
        "meson"
      ],
      "compilers": [
        "cc",
        "gcc",
        "clang",
        "go",
        "rustc"
      ],
      "debuggers": [
        "gdb",
        "lldb"
      ],
      "docs": [
        "man",
        "apropos",
        "info"
      ],
      "elf_tools": [
        "readelf",
        "objdump",
        "nm",
        "addr2line"
      ],
      "network": [
        "ping",
        "nc",
        "curl",
        "wget",
        "ssh",
        "scp",
        "rsync"
      ],
      "shells": [
        "sh",
        "bash",
        "zsh",
        "ksh",
        "fish"
      ],
      "system": [
        "uname",
        "sysctl",
        "dmesg",
        "mount",
        "ps",
        "top"
      ],
      "text": [
        "awk",
        "sed",
        "grep",
        "find",
        "xargs"
      ],
      "tracers": [
        "strace",
        "truss",
        "ktrace",
        "dtrace",
        "perf",
        "bpftrace"
      ]
    }
  },
  "targets": {
    "local": {
      "type": "local",
      "default": true
    }
  },
  "mcp_servers": {},
  "tooling": {
    "mode": "auto",
    "max_tool_rounds": 25
  },
  "output": {
    "max_tool_output_chars": 50000,
    "prefer_structured_content": true,
    "include_raw_mcp_envelope": false,
    "compact_shell_results": true,
    "terminal_passthrough": true
  },
  "mcp": {
    "cache_tools": true,
    "cache_ttl_seconds": 3600,
    "startup_concurrency": true
  },
  "transcripts": {
    "dir": "~/.katty/sessions",
    "format": "jsonl"
  }
}
